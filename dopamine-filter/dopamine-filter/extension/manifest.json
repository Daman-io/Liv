{
  "manifest_version": 3,
  "name": "Mindful Feed - Dopamine Filter for YouTube",
  "version": "1.0.0",
  "description": "Label videos as dopamine-driven or productive, train a classifier, and filter your YouTube feed automatically.",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://www.googleapis.com/*",
    "http://localhost:5000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Mindful Feed"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
